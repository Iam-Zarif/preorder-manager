generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum PreorderWhen {
  OUT_OF_STOCK
  REGARDLESS_OF_STOCK
}

model Preorder {
  id            String       @id @default(cuid())
  name          String
  products      Int
  preorderWhen  PreorderWhen

  startsAt      DateTime
  endsAt        DateTime?

  status        Boolean      @default(true)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

